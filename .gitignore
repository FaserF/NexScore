.packages
.pub-cache/
.pub/
build/
*.dart_snapshot
*.jit

# Generated files
*.freezed.dart
*.g.dart
*.gen.dart

# -----------------------------------------------
# Android
# -----------------------------------------------
score_play/android/.gradle/
score_play/android/captures/
